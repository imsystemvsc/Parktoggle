<Window x:Class="ParkToggleWpf.MonitoringSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:monitoring="clr-namespace:ParkToggleWpf.Monitoring"
        mc:Ignorable="d"
        Title="Configure Monitoring Sensors"
        Height="620"
        Width="680"
        MinHeight="480"
        MinWidth="540"
        WindowStartupLocation="CenterOwner"
        Background="#14151B"
        BorderBrush="#2C2E37"
        BorderThickness="1">
    <Window.Resources>
        <Style x:Key="OverlayScrollBarRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SlimScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Root" Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" Orientation="{TemplateBinding Orientation}" IsDirectionReversed="True" Focusable="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton x:Name="DecreaseButton" Command="{x:Static ScrollBar.LineUpCommand}" Style="{StaticResource OverlayScrollBarRepeatButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton x:Name="IncreaseButton" Command="{x:Static ScrollBar.LineDownCommand}" Style="{StaticResource OverlayScrollBarRepeatButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#444856" Opacity="0.75" CornerRadius="4" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="Root" Property="Height" Value="{Binding Width, RelativeSource={RelativeSource TemplatedParent}}" />
                                <Setter TargetName="Root" Property="Width" Value="Auto" />
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                                <Setter TargetName="DecreaseButton" Property="Command" Value="{x:Static ScrollBar.LineLeftCommand}" />
                                <Setter TargetName="IncreaseButton" Property="Command" Value="{x:Static ScrollBar.LineRightCommand}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1E1F27" />
            <Setter Property="Foreground" Value="#9AA0AE" />
            <Setter Property="BorderBrush" Value="#2C2E37" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12 5" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A2D38" />
                                <Setter Property="Foreground" Value="#EEF0F4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="CONFIGURE MONITORING SENSORS"
                       FontFamily="Bahnschrift"
                       Foreground="#EEF0F4"
                       FontSize="18"
                       FontWeight="SemiBold" />
            <TextBlock Text="Check sensors to pin them to the hardware category cards on your Monitoring tab"
                       Foreground="#9AA0AE"
                       FontSize="12"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- Search & Action Toolbar -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Search Box -->
            <Border Grid.Column="0"
                    Background="#1E1F27"
                    BorderBrush="#2C2E37"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10,4"
                    Margin="0,0,12,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="🔍"
                               Foreground="#666666"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />

                    <TextBox x:Name="SearchBox"
                             Grid.Column="1"
                             Background="Transparent"
                             Foreground="#EEF0F4"
                             CaretBrush="#EEF0F4"
                             BorderThickness="0"
                             FontSize="13"
                             VerticalContentAlignment="Center"
                             TextChanged="SearchBox_TextChanged" />

                    <Button x:Name="ClearSearchButton"
                            Grid.Column="2"
                            Content="✕"
                            Foreground="#888888"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="12"
                            Cursor="Hand"
                            Visibility="Collapsed"
                            Click="ClearSearch_Click"
                            VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- Quick Actions -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Select All" Style="{StaticResource ActionButtonStyle}" Margin="0,0,6,0" Click="SelectAll_Click" />
                <Button Content="Clear All" Style="{StaticResource ActionButtonStyle}" Margin="0,0,6,0" Click="DeselectAll_Click" />
                <Button Content="Expand All" Style="{StaticResource ActionButtonStyle}" Margin="0,0,6,0" Click="ExpandAll_Click" />
                <Button Content="Collapse All" Style="{StaticResource ActionButtonStyle}" Click="CollapseAll_Click" />
            </StackPanel>
        </Grid>

        <!-- Sensor Tree Area -->
        <Border Grid.Row="2"
                Background="#1E1F27"
                BorderBrush="#2C2E37"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8">
            <Grid>
                <TreeView x:Name="SensorTree"
                          ItemsSource="{Binding SensorTreeNodes}"
                          Background="Transparent"
                          BorderThickness="0"
                          Foreground="#EEF0F4"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <TreeView.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource SlimScrollBarStyle}" />
                        
                        <!-- Hardware Node Template -->
                        <HierarchicalDataTemplate DataType="{x:Type monitoring:MonitoringHardwareNode}" ItemsSource="{Binding Children}">
                            <Border Background="#252834" CornerRadius="6" Padding="8,6" Margin="0,4,8,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsSelectedState, Mode=TwoWay}"
                                              IsThreeState="True"
                                              VerticalAlignment="Center"
                                              Margin="0,0,10,0"
                                              Focusable="False" />
                                              
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding HardwareIcon}"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                               
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Name}"
                                               FontFamily="Bahnschrift"
                                               Foreground="#EEF0F4"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </HierarchicalDataTemplate>
                        
                        <!-- Sensor Group Node Template -->
                        <HierarchicalDataTemplate DataType="{x:Type monitoring:MonitoringSensorGroupNode}" ItemsSource="{Binding Children}">
                            <Border Padding="4,4" Margin="0,2,8,2">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <CheckBox IsChecked="{Binding IsSelectedState, Mode=TwoWay}"
                                              IsThreeState="True"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0"
                                              Focusable="False" />
                                    <TextBlock Text="{Binding Name}"
                                               FontFamily="Bahnschrift"
                                               Foreground="#A0A5B5"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </HierarchicalDataTemplate>
                        
                        <!-- Sensor Leaf Node Template -->
                        <DataTemplate DataType="{x:Type monitoring:MonitoringSensorLeafNode}">
                            <Border Background="#191A21"
                                    BorderBrush="#292C36"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8,6"
                                    Margin="0,2,8,2">
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsSelectedState, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,10,0"
                                              Focusable="False" />
                                              
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SensorIcon}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                               
                                    <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Sensor.SensorDisplayName}"
                                                   Foreground="#EEF0F4"
                                                   FontSize="12.5"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Sensor.GroupDisplayName}"
                                                   Foreground="#666875"
                                                   FontSize="10.5" />
                                    </StackPanel>
                                    
                                    <TextBlock Grid.Column="3"
                                               Margin="16,0,0,0"
                                               Text="{Binding Sensor.CurrentDisplay}"
                                               FontFamily="Consolas, Cascadia Code, Courier New"
                                               Foreground="#A7C47E"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </TreeView.Resources>
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                            <Setter Property="Foreground" Value="#EEF0F4" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>

                <TextBlock x:Name="EmptyTreeMessage"
                           Text="No sensors match your search filter."
                           Foreground="#9AA0AE"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed" />
            </Grid>
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Changes take effect immediately on your Monitoring tab."
                       Foreground="#666875"
                       FontSize="11.5"
                       VerticalAlignment="Center" />

            <Button Grid.Column="1"
                    Content="Done"
                    Width="110"
                    Padding="0,8"
                    Foreground="#14151B"
                    Background="#A7C47E"
                    BorderBrush="#A7C47E"
                    BorderThickness="1"
                    FontFamily="Bahnschrift"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Click="CloseButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#B9D68E" />
                                <Setter TargetName="b" Property="BorderBrush" Value="#B9D68E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>
