<Window x:Class="ParkToggleWpf.MonitoringSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:monitoring="clr-namespace:ParkToggleWpf.Monitoring"
        mc:Ignorable="d"
        Title="Configure Monitoring Sensors"
        Height="620"
        Width="680"
        MinHeight="480"
        MinWidth="540"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource DialogBackgroundBrush}"
        BorderBrush="{StaticResource CardBorderBrush}"
        BorderThickness="1">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="CONFIGURE MONITORING SENSORS"
                       FontFamily="Bahnschrift"
                       Foreground="{StaticResource ForegroundBrush}"
                       FontSize="18"
                       FontWeight="SemiBold" />
            <TextBlock Text="Check sensors to pin them to the hardware category cards on your Monitoring tab"
                       Foreground="{StaticResource MutedBrush}"
                       FontSize="12"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- Search & Action Toolbar -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Search Box -->
            <Border Grid.Column="0"
                    Background="#1B1D26"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10,4"
                    Margin="0,0,12,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="🔍"
                               Foreground="{StaticResource SubtleMutedBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />

                    <TextBox x:Name="SearchBox"
                             Grid.Column="1"
                             Background="Transparent"
                             Foreground="{StaticResource ForegroundBrush}"
                             CaretBrush="{StaticResource ForegroundBrush}"
                             BorderThickness="0"
                             FontSize="13"
                             VerticalContentAlignment="Center"
                             TextChanged="SearchBox_TextChanged" />

                    <Button x:Name="ClearSearchButton"
                            Grid.Column="2"
                            Content="✕"
                            Foreground="{StaticResource MutedBrush}"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="12"
                            Cursor="Hand"
                            Visibility="Collapsed"
                            Click="ClearSearch_Click"
                            VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- Quick Actions -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Select All" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0" Click="SelectAll_Click" />
                <Button Content="Clear All" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0" Click="DeselectAll_Click" />
                <Button Content="Expand All" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0" Click="ExpandAll_Click" />
                <Button Content="Collapse All" Style="{StaticResource SecondaryButtonStyle}" Click="CollapseAll_Click" />
            </StackPanel>
        </Grid>

        <!-- Sensor Tree Area -->
        <Border Grid.Row="2"
                Background="#161820"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8">
            <Grid>
                <TreeView x:Name="SensorTree"
                          ItemsSource="{Binding SensorTreeNodes}"
                          Background="Transparent"
                          BorderThickness="0"
                          Foreground="{StaticResource ForegroundBrush}">
                    <TreeView.Resources>
                        <!-- Hardware Node Template -->
                        <HierarchicalDataTemplate DataType="{x:Type monitoring:MonitoringHardwareNode}" ItemsSource="{Binding Children}">
                            <Border Background="#20232E" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="8,6" Margin="0,3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsSelectedState, Mode=TwoWay}"
                                              IsThreeState="True"
                                              VerticalAlignment="Center"
                                              Margin="0,0,10,0"
                                              Focusable="False" />
                                              
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding HardwareIcon}"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                               
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Name}"
                                               FontFamily="Bahnschrift"
                                               Foreground="{StaticResource ForegroundBrush}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </HierarchicalDataTemplate>
                        
                        <!-- Sensor Group Node Template -->
                        <HierarchicalDataTemplate DataType="{x:Type monitoring:MonitoringSensorGroupNode}" ItemsSource="{Binding Children}">
                            <Border Padding="4,4" Margin="0,2">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <CheckBox IsChecked="{Binding IsSelectedState, Mode=TwoWay}"
                                              IsThreeState="True"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0"
                                              Focusable="False" />
                                    <TextBlock Text="{Binding Name}"
                                               FontFamily="Bahnschrift"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </HierarchicalDataTemplate>
                        
                        <!-- Sensor Leaf Node Template -->
                        <DataTemplate DataType="{x:Type monitoring:MonitoringSensorLeafNode}">
                            <Border Background="#1A1C25"
                                    BorderBrush="#252834"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8,6"
                                    Margin="0,2">
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsSelectedState, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,10,0"
                                              Focusable="False" />
                                              
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SensorIcon}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                               
                                    <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Sensor.SensorDisplayName}"
                                                   Foreground="{StaticResource ForegroundBrush}"
                                                   FontSize="12.5"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Sensor.GroupDisplayName}"
                                                   Foreground="{StaticResource SubtleMutedBrush}"
                                                   FontSize="10.5" />
                                    </StackPanel>
                                    
                                    <TextBlock Grid.Column="3"
                                               Margin="16,0,0,0"
                                               Text="{Binding Sensor.CurrentDisplay}"
                                               FontFamily="Consolas, Cascadia Code, Courier New"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </TreeView.Resources>
                </TreeView>

                <TextBlock x:Name="EmptyTreeMessage"
                           Text="No sensors match your search filter."
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed" />
            </Grid>
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Changes take effect immediately on your Monitoring tab."
                       Foreground="{StaticResource SubtleMutedBrush}"
                       FontSize="11.5"
                       VerticalAlignment="Center" />

            <Button Grid.Column="1"
                    Content="Done"
                    Width="110"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="CloseButton_Click" />
        </Grid>
    </Grid>
</Window>
