<Window x:Class="ParkToggleWpf.ProcessPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Running Application" 
        Height="480" Width="440"
        WindowStartupLocation="CenterOwner"
        Background="#14151B" Foreground="#EEF0F4"
        BorderBrush="#2C2E37" BorderThickness="1"
        FontFamily="Bahnschrift">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,16">
            <TextBlock Text="SELECT RUNNING APPLICATION" 
                       FontFamily="Bahnschrift"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="#EEF0F4"/>
            <TextBlock Text="Choose an active process to trigger automation profile"
                       FontSize="11.5" Foreground="#9AA0AE" Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="#1E1F27" BorderBrush="#2C2E37" BorderThickness="1" CornerRadius="8" Padding="6">
            <ListBox x:Name="ProcessList" 
                     Background="Transparent"
                     BorderThickness="0"
                     MouseDoubleClick="ProcessList_MouseDoubleClick"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Grid.Column="0" Source="{Binding Icon}" Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding ProcessName}" FontFamily="Bahnschrift" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" Foreground="#EEF0F4" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="2" Text="{Binding MainWindowTitle}" FontFamily="Consolas, Cascadia Code, Courier New" Foreground="#9AA0AE" FontSize="11.5" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="8,0,0,0"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Click="Cancel_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
            <Button Content="Select Application" Click="Select_Click" Style="{StaticResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
