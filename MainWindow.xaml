<Window x:Class="ParkToggleWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:monitoring="clr-namespace:ParkToggleWpf.Monitoring"
        xmlns:converters="clr-namespace:ParkToggleWpf.Converters"
        xmlns:tb="clr-namespace:H.NotifyIcon;assembly=H.NotifyIcon.Wpf"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        mc:Ignorable="d"
        Title="Park Toggle"
        Height="680"
        Width="940"
        MinHeight="600"
        MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#121217">
    <Window.Resources>
        <converters:CoreNameToNumberConverter x:Key="CoreNameToNumberConverter" />
        <SolidColorBrush x:Key="WindowGradientTop" Color="#191919" />
        <SolidColorBrush x:Key="WindowGradientBottom" Color="#121212" />
        <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#191919" Offset="0" />
            <GradientStop Color="#121212" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#222222" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#333333" />
        <SolidColorBrush x:Key="ForegroundBrush" Color="#F0F0F0" />
        <SolidColorBrush x:Key="MutedBrush" Color="#888888" />
        <SolidColorBrush x:Key="AccentBrush" Color="#00D084" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#00E691" />
        <SolidColorBrush x:Key="AccentPressedBrush" Color="#00B371" />
                <Style x:Key="OverlayScrollBarRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SlimScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="Background" Value="#151822" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Root" Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" Orientation="{TemplateBinding Orientation}" IsDirectionReversed="True" Focusable="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton x:Name="DecreaseButton" Command="{x:Static ScrollBar.LineUpCommand}" Style="{StaticResource OverlayScrollBarRepeatButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton x:Name="IncreaseButton" Command="{x:Static ScrollBar.LineDownCommand}" Style="{StaticResource OverlayScrollBarRepeatButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#8CA9FF" Opacity="0.75" CornerRadius="4" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="Root" Property="Height" Value="{Binding Width, RelativeSource={RelativeSource TemplatedParent}}" />
                                <Setter TargetName="Root" Property="Width" Value="Auto" />
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                                <Setter TargetName="DecreaseButton" Property="Command" Value="{x:Static ScrollBar.LineLeftCommand}" />
                                <Setter TargetName="IncreaseButton" Property="Command" Value="{x:Static ScrollBar.LineRightCommand}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <SolidColorBrush x:Key="SecondaryBorderBrush" Color="#444444" />
        <SolidColorBrush x:Key="AlwaysOnBrush" Color="#FF5C00" />
        <SolidColorBrush x:Key="AlwaysOnHoverBrush" Color="#FF7020" />
        <SolidColorBrush x:Key="AlwaysOnPressedBrush" Color="#E05100" />
        <SolidColorBrush x:Key="AlwaysOnTextBrush" Color="#FFFFFF" />

        <DropShadowEffect x:Key="CardShadow" BlurRadius="10" Opacity="0.2" ShadowDepth="4" Color="#000000" />
        <ControlTemplate x:Key="RoundedComboToggleButton" TargetType="ToggleButton">
            <Border x:Name="ToggleBorder"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    CornerRadius="0">
                <Path Data="M 0 0 L 5 5 L 10 0"
                      Stroke="#9AA0AE"
                      StrokeThickness="2"
                      HorizontalAlignment="Right"
                      Margin="0,0,18,0"
                      VerticalAlignment="Center"
                      StrokeEndLineCap="Round"
                      StrokeStartLineCap="Round"
                      StrokeLineJoin="Round" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="ToggleBorder" Property="Opacity" Value="0.6" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="RoundedComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            <Setter Property="Background" Value="#1C1C1C" />
            <Setter Property="BorderBrush" Value="#333333" />
            <Setter Property="Padding" Value="12 8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="BackgroundBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="2" />
                            <ContentPresenter Margin="14,4,36,4"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              IsHitTestVisible="False" />
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource RoundedComboToggleButton}"
                                          Background="Transparent"
                                          BorderBrush="Transparent"
                                          Focusable="False"
                                          IsTabStop="False"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" />
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Slide">
                                <Grid MaxHeight="220" MinWidth="{TemplateBinding ActualWidth}">
                                    <Border Background="#1C1C1C"
                                            BorderBrush="#333333"
                                            BorderThickness="1"
                                            CornerRadius="2">
                                        <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                            <StackPanel>
                                                <ItemsPresenter />
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="BackgroundBorder" Property="MinHeight" Value="36" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="BorderBrush" Value="#555555" />
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="#2A2A2A" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="BackgroundBorder" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

                <Style x:Key="ChipButtonBaseStyle" TargetType="Button">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="20 8" />
            <Setter Property="BorderBrush" Value="{StaticResource SecondaryBorderBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

                

        <Style x:Key="WarningButtonStyle" TargetType="Button" BasedOn="{StaticResource ChipButtonBaseStyle}">
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Background" Value="#FF5C00" />
            <Setter Property="BorderBrush" Value="#FF5C00" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF7020" />
                    <Setter Property="BorderBrush" Value="#FF7020" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#E05100" />
                    <Setter Property="BorderBrush" Value="#E05100" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#803400" />
                    <Setter Property="BorderBrush" Value="#803400" />
                    <Setter Property="Foreground" Value="#AAAAAA" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ListRowItemStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0 2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="RowBorder"
                                Background="Transparent"
                                CornerRadius="0"
                                BorderThickness="0 0 0 1"
                                BorderBrush="#333333"
                                Padding="0">
                            <ContentPresenter Margin="12 6"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="#2A2A2A" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="#333333" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RowBorder" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

<Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ChipButtonBaseStyle}">
            <Setter Property="Foreground" Value="#000000" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentPressedBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentPressedBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#7F8ACF" />
                    <Setter Property="BorderBrush" Value="#7F8ACF" />
                    <Setter Property="Foreground" Value="#2B2D35" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ChipButtonBaseStyle}">
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="BorderBrush" Value="{StaticResource SecondaryBorderBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#383838" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1C1C1C" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#222222" />
                    <Setter Property="BorderBrush" Value="#2E2E2E" />
                    <Setter Property="Foreground" Value="#666666" />
                </Trigger>
            </Style.Triggers>
        </Style>



        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16 8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border"
                                Background="Transparent"
                                CornerRadius="2"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}"
                                Margin="0,0,8,0">
                            <ContentPresenter x:Name="ContentSite"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#222222" />
                                <Setter TargetName="Border" Property="BorderBrush" Value="#333333" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2A2A2A" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

        <Window.TaskbarItemInfo>
        <TaskbarItemInfo ProgressState="{Binding ViewModel.TaskbarProgressState}" 
                         ProgressValue="{Binding ViewModel.TaskbarProgressValue}" />
    </Window.TaskbarItemInfo>
    <Grid Background="{StaticResource WindowBackgroundBrush}">

        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="Park Toggle"
                        IconSource="{Binding ViewModel.TrayIconSource}"
                        MenuActivation="RightClick"
                        TrayMouseDoubleClick="TaskbarIcon_TrayMouseDoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <ContextMenu.Resources>
                        <SolidColorBrush x:Key="MenuBackgroundBrush" Color="#1E1F27" />
                        <SolidColorBrush x:Key="MenuBorderBrush" Color="#2C2E37" />
                        <SolidColorBrush x:Key="MenuForegroundBrush" Color="#EEF0F4" />
                        <SolidColorBrush x:Key="MenuHighlightBrush" Color="#2A2D38" />

                        <Style TargetType="ContextMenu">
                            <Setter Property="Background" Value="{StaticResource MenuBackgroundBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource MenuForegroundBrush}" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="BorderBrush" Value="{StaticResource MenuBorderBrush}" />
                            <Setter Property="Padding" Value="4" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ContextMenu">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8"
                                                Padding="{TemplateBinding Padding}">
                                            <ItemsPresenter />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <Style TargetType="MenuItem">
                            <Setter Property="OverridesDefaultStyle" Value="True" />
                            <Setter Property="Foreground" Value="{StaticResource MenuForegroundBrush}" />
                            <Setter Property="Padding" Value="12 8" />
                            <Setter Property="Margin" Value="4 2" />
                            <Setter Property="FontSize" Value="13" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="MenuItem">
                                        <Border x:Name="Border"
                                                Background="Transparent"
                                                CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="20" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter ContentSource="Icon" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                <ContentPresenter Grid.Column="1" ContentSource="Header" VerticalAlignment="Center" Margin="12 0 0 0" RecognizesAccessKey="True" TextElement.Foreground="{TemplateBinding Foreground}"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="{StaticResource MenuHighlightBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Foreground" Value="#6B7280" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <Style TargetType="Separator">
                            <Setter Property="OverridesDefaultStyle" Value="True" />
                            <Setter Property="Height" Value="1" />
                            <Setter Property="Margin" Value="12 4" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Separator">
                                        <Border Background="{StaticResource MenuBorderBrush}" Height="1" />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ContextMenu.Resources>

                    <MenuItem Header="{Binding ViewModel.ModeValueText, StringFormat=Current Mode: \{0\}}" IsEnabled="False">
                        <MenuItem.Icon>
                            <Image Source="{Binding ViewModel.TrayIconSource}" Width="16" Height="16" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Switch Mode" Command="{Binding ViewModel.ToggleModeCommand}">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE8AB;" FontSize="15" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Show Dashboard" Click="ShowWindow_Click">
                        <MenuItem.Icon>
                            <Image Source="pack://application:,,,/Resources/Icons/main.ico" Width="16" Height="16" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Open Log" Command="{Binding ViewModel.OpenLogCommand}">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE7C3;" FontSize="15" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="System Tools" IsEnabled="False" Foreground="#F5A24C" FontWeight="SemiBold">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE713;" FontSize="15" Foreground="#F5A24C" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Empty Recycle Bin" Click="EmptyRecycleBin_Click">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE74D;" FontSize="15" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Restart Explorer" Click="RestartExplorer_Click">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE72C;" FontSize="15" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Open Task Manager" Click="OpenTaskManager_Click">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE7F4;" FontSize="15" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Open Power Options" Click="OpenPowerOptions_Click">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE836;" FontSize="15" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Flush DNS Cache" Click="FlushDNS_Click">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE774;" FontSize="15" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Exit" Click="Exit_Click">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE7E8;" FontSize="15" />
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <Border Padding="24"
                CornerRadius="2"
                Margin="16"
                BorderBrush="#333333"
                BorderThickness="1"
                Background="{StaticResource CardBackgroundBrush}"
                Effect="{StaticResource CardShadow}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="PARK TOGGLE"
                           FontFamily="Bahnschrift"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{StaticResource ForegroundBrush}"
                           Margin="0 0 0 24" />

                <TabControl Grid.Row="1">
                                                                    <TabItem Header="Overview">
        <Grid Margin="0,16,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <!-- LEFT COLUMN -->
            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <!-- Card 1: Power Profile -->
                <Border Background="#1C1C1C" CornerRadius="2" Padding="20" Margin="0,0,0,16" BorderBrush="#333333" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="POWER PROFILE" FontFamily="Bahnschrift" Foreground="{StaticResource MutedBrush}" FontSize="13" Margin="0,0,0,12" />
                        <ComboBox x:Name="PlanCombo" 
                                  ItemsSource="{Binding ViewModel.Plans}" 
                                  SelectedItem="{Binding ViewModel.SelectedPlan}" 
                                  DisplayMemberPath="Name">
                            <ComboBox.Style>
                                <Style TargetType="ComboBox" BasedOn="{StaticResource RoundedComboBoxStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ViewModel.IsBusy}" Value="True">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ComboBox.Style>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Card 2: Quick Actions -->
                <Border Background="#1C1C1C" CornerRadius="2" Padding="20" BorderBrush="#333333" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="QUICK ACTIONS" FontFamily="Bahnschrift" Foreground="{StaticResource MutedBrush}" FontSize="13" Margin="0,0,0,12" />
                        
                        <Button Command="{Binding ViewModel.ToggleModeCommand}" Content="Switch to Cool Idle" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ViewModel.CurrentMode}" Value="AlwaysOn">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Command="{Binding ViewModel.ToggleModeCommand}" Content="Switch to Always-On" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource WarningButtonStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ViewModel.CurrentMode}" Value="CoolIdle">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        
                        <Button Content="Refresh Sensors &amp; Data" Command="{Binding ViewModel.RefreshCommand}" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Stretch" Margin="0,0,0,16" />
                        
                        <CheckBox Content="Start with Windows (Minimized)" 
                                  IsChecked="{Binding ViewModel.StartWithWindows, Mode=TwoWay}" 
                                  Foreground="{StaticResource MutedBrush}" />
                    </StackPanel>
                </Border>
            </StackPanel>
            
            <!-- RIGHT COLUMN -->
            <StackPanel Grid.Column="1">
                <!-- Card 3: Thermals & Telemetry -->
                <Border Background="#1C1C1C" CornerRadius="2" Padding="20" Margin="0,0,0,16" BorderBrush="#333333" BorderThickness="1">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="CPU TEMPERATURE" FontFamily="Bahnschrift" Foreground="{StaticResource MutedBrush}" FontSize="13" />
                                <TextBlock Text="{Binding ViewModel.PackageTempText}" FontFamily="Consolas, Cascadia Code, Courier New" Margin="0,4,0,0" FontSize="42" FontWeight="SemiBold" Foreground="{StaticResource ForegroundBrush}" />
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="MODE:" FontFamily="Bahnschrift" Foreground="{StaticResource MutedBrush}" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Grid.Column="1" Text="{Binding ViewModel.ModeValueText}" FontFamily="Bahnschrift" FontSize="13" FontWeight="Bold" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ViewModel.CurrentMode}" Value="AlwaysOn">
                                                        <Setter Property="Foreground" Value="{StaticResource AlwaysOnBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ViewModel.CurrentMode}" Value="CoolIdle">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                
                                <TextBlock Text="{Binding ViewModel.AutomationStatusText}" FontFamily="Consolas, Cascadia Code, Courier New" Foreground="{StaticResource AccentBrush}" FontSize="12" Margin="0,0,0,8" />
                                
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Text="{Binding ViewModel.CoreLabel}" ToolTip="Core Parking Min Cores (AC/DC)" FontFamily="Consolas, Cascadia Code, Courier New" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,2" />
                                    <TextBlock Text="{Binding ViewModel.IdleLabel}" ToolTip="Idle State Max (AC/DC)" FontFamily="Consolas, Cascadia Code, Courier New" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        
                        <lvc:CartesianChart
                            Series="{Binding ViewModel.TemperatureSeries}"
                            Height="45"
                            Margin="0,16,0,0"
                            Background="Transparent"
                            TooltipPosition="Hidden"
                            XAxes="{Binding ViewModel.EmptyAxes}"
                            YAxes="{Binding ViewModel.TempYAxes}">
                        </lvc:CartesianChart>
                    </StackPanel>
                </Border>

                <!-- Card 4: Core Parking Status -->
                <Border Background="#1C1C1C" CornerRadius="2" Padding="20" BorderBrush="#333333" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="LOGICAL CORE TOPOGRAPHY MAP" FontFamily="Bahnschrift" Foreground="{StaticResource MutedBrush}" FontSize="13" Margin="0,0,0,12" />
                        
                        <ItemsControl ItemsSource="{Binding ViewModel.Cores}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="0" Margin="1,0" ToolTip="{Binding CoreName}" Width="12" Height="40" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                <Setter Property="BorderBrush" Value="#00FF9D" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsParked}" Value="True">
                                                        <Setter Property="Background" Value="#151515" />
                                                        <Setter Property="BorderBrush" Value="#333333" />
                                                        <Setter Property="Height" Value="32" />
                                                        <Setter Property="Margin" Value="1,4" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DataContext.ViewModel.CurrentMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="AlwaysOn">
                                                        <Setter Property="Background" Value="{StaticResource AlwaysOnBrush}" />
                                                        <Setter Property="BorderBrush" Value="#FF9D00" />
                                                    </DataTrigger>
                                                    <!-- Re-apply parked style logic if parked in AlwaysOn (though unlikely) -->
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsParked}" Value="True" />
                                                            <Condition Binding="{Binding DataContext.ViewModel.CurrentMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="AlwaysOn" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="#151515" />
                                                        <Setter Property="BorderBrush" Value="#333333" />
                                                        <Setter Property="Height" Value="32" />
                                                        <Setter Property="Margin" Value="1,4" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
</TabItem>
<TabItem Header="Monitoring">
                        <Border Background="#1C1C1C"
                                CornerRadius="2"
                                Padding="24"
                                Margin="0 0 0 16"
                                BorderBrush="#333333"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="ACTIVE SENSORS"
                                               FontFamily="Bahnschrift"
                                               Foreground="{StaticResource ForegroundBrush}"
                                               FontSize="16" />
                                    <Button Grid.Column="1"
                                            Content="Settings"
                                            Margin="12 0 0 0"
                                            Padding="18 6"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="OpenMonitoringSettings_Click" />
                                </Grid>

                                <Grid Grid.Row="1" Margin="0 16 0 0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Border Background="#1C1C1C"
                                                BorderBrush="#333333"
                                                BorderThickness="1"
                                                CornerRadius="2">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>

                                                <Grid Margin="12 0 22 6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="100" />
                                                        <ColumnDefinition Width="80" />
                                                        <ColumnDefinition Width="80" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="SENSOR"
                                                               FontFamily="Bahnschrift"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               FontSize="12" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="CURRENT"
                                                               Margin="24 0 0 0"
                                                               FontFamily="Bahnschrift"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               FontSize="12"
                                                               HorizontalAlignment="Right" />
                                                    <TextBlock Grid.Column="2"
                                                               Text="MIN"
                                                               Margin="24 0 0 0"
                                                               FontFamily="Bahnschrift"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               FontSize="12"
                                                               HorizontalAlignment="Right" />
                                                    <TextBlock Grid.Column="3"
                                                               Text="MAX"
                                                               Margin="24 0 0 0"
                                                               FontFamily="Bahnschrift"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               FontSize="12"
                                                               HorizontalAlignment="Right" />
                                                </Grid>

                                                <ListView Grid.Row="1"
                                                          x:Name="ActiveSensorsList"
                                                          ItemsSource="{Binding MonitoringSensorsView}"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          Foreground="{StaticResource ForegroundBrush}"
                                                          ScrollViewer.VerticalScrollBarVisibility="Visible"
                                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                          HorizontalContentAlignment="Stretch"
                                                          Margin="0"
                                                          AllowDrop="True"
                                                          PreviewMouseWheel="ActiveSensorsList_PreviewMouseWheel"
                                                          PreviewMouseLeftButtonDown="ActiveSensorsList_PreviewMouseLeftButtonDown"
                                                          MouseMove="ActiveSensorsList_MouseMove"
                                                          DragOver="ActiveSensorsList_DragOver"
                                                          Drop="ActiveSensorsList_Drop"
                                                          ItemContainerStyle="{StaticResource ListRowItemStyle}">
                                                    <ListView.Resources>
                                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource SlimScrollBarStyle}" />
                                                    </ListView.Resources>
                                                    <ListView.GroupStyle>
                                                        <GroupStyle>
                                                            <GroupStyle.HeaderTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="#161821"
                                                                            Padding="8 4"
                                                                            CornerRadius="8"
                                                                            Margin="0 12 0 4">
                                                                        <TextBlock Text="{Binding Name}"
                                                                                   Foreground="{StaticResource MutedBrush}"
                                                                                   FontSize="13"
                                                                                   FontWeight="SemiBold" />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </GroupStyle.HeaderTemplate>
                                                            <GroupStyle.Panel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel />
                                                                </ItemsPanelTemplate>
                                                            </GroupStyle.Panel>
                                                        </GroupStyle>
                                                    </ListView.GroupStyle>
                                                    <ListView.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border BorderThickness="0,0,0,1" BorderBrush="#2C2E37" Padding="0,8">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="100" />
                                                                        <ColumnDefinition Width="80" />
                                                                        <ColumnDefinition Width="80" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="{Binding SensorDisplayName}"
                                                                               Foreground="{StaticResource MutedBrush}"
                                                                               FontSize="14"
                                                                               FontWeight="SemiBold"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock Grid.Column="1"
                                                                               Text="{Binding CurrentDisplay}"
                                                                               Margin="24 0 0 0"
                                                                               FontSize="15"
                                                                               FontWeight="SemiBold"
                                                                               HorizontalAlignment="Right" />
                                                                    <TextBlock Grid.Column="2"
                                                                               Text="{Binding MinDisplay}"
                                                                               Margin="24 0 0 0"
                                                                               HorizontalAlignment="Right"
                                                                               FontSize="13" />
                                                                    <TextBlock Grid.Column="3"
                                                                               Text="{Binding MaxDisplay}"
                                                                               Margin="24 0 0 0"
                                                                               HorizontalAlignment="Right"
                                                                               FontSize="13" />
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ListView.ItemTemplate>
                                                </ListView>
                                            </Grid>
                                        </Border>


                                        <TextBlock Text="No sensors selected. Open Settings to choose sensors."
                                                   Foreground="{StaticResource MutedBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="14">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding MonitoringSensorsView.IsEmpty}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </TabItem>
                    
                    <TabItem Header="Automation">
                        <Border Background="#1B1D26"
                                CornerRadius="20"
                                Padding="24"
                                Margin="0 0 0 16"
                                BorderBrush="#2C2E37"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!-- Smart Battery Toggle -->
                                <StackPanel Grid.Row="0" Margin="0,0,0,24">
                                    <TextBlock Text="Smart Battery Detection" Foreground="{StaticResource ForegroundBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4" />
                                    <TextBlock Text="Automatically forces 'Cool Idle' when unplugged, ignoring games." Foreground="{StaticResource MutedBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,12" />
                                    <CheckBox Content="Enable Smart Battery Override" IsChecked="{Binding ViewModel.AutomationSettings.SmartBatteryEnabled}" Foreground="{StaticResource ForegroundBrush}" />
                                </StackPanel>

                                <!-- Game Auto-Switching -->
                                <Grid Grid.Row="1" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Game Auto-Switching" Foreground="{StaticResource ForegroundBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4" />
                                        <TextBlock Text="Forces 'Always-On' when these apps are running." Foreground="{StaticResource MutedBrush}" FontSize="13" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Pick Running..." Command="{Binding ViewModel.AddRunningGameCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="16 8" Margin="0 0 10 0" />
                                    <Button Grid.Column="2" Content="Browse..." Command="{Binding ViewModel.AddGameExecutableCommand}" Style="{StaticResource PrimaryButtonStyle}" Padding="16 8" />
                                </Grid>

                                <!-- Configured Games List -->
                                <Border Grid.Row="2" Background="#161821" BorderBrush="#2C2E37" BorderThickness="1" CornerRadius="12" Padding="8">
                                    <ListView ItemsSource="{Binding ViewModel.TargetExecutableViewModels}" 
                                              Background="Transparent" BorderThickness="0" Foreground="{StaticResource ForegroundBrush}"
                                              ItemContainerStyle="{StaticResource ListRowItemStyle}">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,12,0" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}" Foreground="{StaticResource ForegroundBrush}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                    <Button Grid.Column="2" 
                                                            Content="✕" 
                                                            Command="{Binding DataContext.ViewModel.RemoveGameExecutableCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Foreground="{StaticResource MutedBrush}"
                                                            FontSize="16"
                                                            Cursor="Hand"
                                                            FontWeight="Bold"
                                                            Padding="8,0"
                                                            ToolTip="Remove Game" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </Border>
                            </Grid>
                        </Border>
                    </TabItem>

                
                                                        </TabControl>

            </Grid>

        </Border>

    </Grid>

</Window>






